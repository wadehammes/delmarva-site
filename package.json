{
	"name": "delmarva-site",
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"private": true,
	"pnpm": {
		"overrides": {
			"@types/mapbox__point-geometry": "file:./patches/@types/mapbox__point-geometry"
		}
	},
	"scripts": {
		"dev": "next dev -p 5656 --webpack",
		"dev:debug": "NODE_OPTIONS='--inspect' next dev -p 5656 --webpack",
		"build": "next build --webpack",
		"build:analyze": "ANALYZE=true next build --webpack",
		"start": "next start -p 5656",
		"export": "next export",
		"tsc:ci": "tsc --strict",
		"lint": "biome check",
		"lint:ci": "biome ci --reporter=github",
		"lint:fix": "biome check --fix",
		"lint:write": "biome check --write",
		"test:ci": "jest --passWithNoTests --runInBand",
		"types:contentful": "export $(cat .env.local | sed '/^#/d; s/[$\"]//g'); cf-content-types-generator -s $CONTENTFUL_SPACE_ID -t $CONTENTFUL_CMA_TOKEN -o src/contentful/types -r -g && biome format --write src/contentful/types",
		"update-readme": "node scripts/update_main_readme.js"
	},
	"dependencies": {
		"@contentful/rich-text-plain-text-renderer": "^17.2.1",
		"@contentful/rich-text-react-renderer": "^16.2.1",
		"@contentful/rich-text-types": "^17.2.7",
		"@next/third-parties": "^16.2.4",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.6",
		"@tanstack/react-query": "^5.99.0",
		"clsx": "^2.1.1",
		"contentful": "^11.12.1",
		"gsap": "^3.15.0",
		"html-react-parser": "^6.0.1",
		"jotai": "^2.19.1",
		"mapbox-gl": "^3.21.0",
		"next": "^16.2.4",
		"next-intl": "^4.9.1",
		"react": "^19.2.5",
		"react-aria": "^3.48.0",
		"react-dom": "^19.2.5",
		"react-google-recaptcha": "^3.1.0",
		"react-hook-form": "^7.72.1",
		"react-intersection-observer": "^10.0.3",
		"resend": "^6.12.0",
		"safe-json-stringify": "^1.2.0",
		"schema-dts": "^2.0.0",
		"server-only": "^0.0.1",
		"sonner": "^2.0.7",
		"swiper": "^12.1.3",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@jest/types": "^30.3.0",
		"@svgr/webpack": "^8.1.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-google-recaptcha": "^2.1.9",
		"@types/safe-json-stringify": "^1.1.5",
		"cf-content-types-generator": "^3.0.1",
		"csstype": "^3.2.3",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"jest-mock": "^30.3.0",
		"postcss-flexbugs-fixes": "^5.0.2",
		"postcss-preset-env": "^11.2.1",
		"react-is": "^19.2.5",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"typescript-plugin-css-modules": "^5.2.0",
		"webpack-bundle-analyzer": "^5.3.0"
	}
}
